<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_bg">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/navy_900"
            app:navigationIconTint="@color/white"
            app:title="@string/create_invoice_title"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content (NestedScrollView) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_lg"
            android:paddingBottom="@dimen/space_xxl">

            <!-- Customer Selection Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_customer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/customer_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <!-- Customer Selection Row -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/customer_row"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="@dimen/space_sm"
                        android:background="@drawable/bg_button_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md">

                        <TextView
                            android:id="@+id/tv_customer_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/select_customer"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/iv_chevron"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/iv_chevron"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/chevron_icon"
                            android:src="@android:drawable/ic_menu_more"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/soft_blue_icon" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Error Message -->
                    <TextView
                        android:id="@+id/tv_customer_error"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/customer_required_error"
                        android:textColor="@android:color/holo_red_light"
                        android:textSize="11sp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Items Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header Row: Items + Add Button -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/space_md">

                        <TextView
                            android:id="@+id/tv_items_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/items_title"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_add_item"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/add_item_button"
                            android:textColor="@color/soft_blue_icon"
                            app:backgroundTint="@android:color/transparent"
                            app:cornerRadius="4dp"
                            app:elevation="0dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:rippleColor="@color/soft_blue"
                            app:strokeColor="@android:color/transparent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Items RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_invoice_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:paddingBottom="@dimen/space_md" />

                    <!-- Empty State Message -->
                    <TextView
                        android:id="@+id/tv_no_items"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginVertical="@dimen/space_lg"
                        android:text="@string/no_items_message"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="@dimen/space_md"
                        android:background="@color/soft_blue" />

                    <!-- Summary Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/dashboard_bg"
                        android:orientation="vertical"
                        android:padding="@dimen/space_md">

                        <!-- Subtotal Row -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/subtotal_label"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tv_subtotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/zero_amount"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <!-- Discount Row -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/discount_label"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tv_discount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/zero_amount"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <!-- Total Row -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/total_label"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tv_total"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/zero_amount"
                                android:textColor="@color/soft_green_icon"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </LinearLayout>

                    <!-- Error Message -->
                    <TextView
                        android:id="@+id/tv_items_error"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_md"
                        android:layout_marginTop="@dimen/space_xs"
                        android:layout_marginEnd="@dimen/space_md"
                        android:layout_marginBottom="@dimen/space_sm"
                        android:text="@string/items_required_error"
                        android:textColor="@android:color/holo_red_light"
                        android:textSize="11sp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Payment Type Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_payment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/payment_type_label"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Payment Type Toggle Group -->
                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggle_payment_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        app:checkedButton="@+id/btn_cash"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_cash"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="@string/payment_cash"
                            android:textSize="13sp"
                            app:cornerRadius="6dp"
                            app:strokeColor="@color/text_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_credit"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="@string/payment_credit"
                            android:textSize="13sp"
                            app:cornerRadius="6dp"
                            app:strokeColor="@color/text_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_cheque"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="@string/payment_cheque"
                            android:textSize="13sp"
                            app:cornerRadius="6dp"
                            app:strokeColor="@color/text_secondary" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <!-- Cheque Details Section (initially hidden) -->
                    <LinearLayout
                        android:id="@+id/container_cheque_details"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!-- Cheque Number Field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_cheque_number"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/cheque_number_hint"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="6dp"
                            app:boxCornerRadiusBottomStart="6dp"
                            app:boxCornerRadiusTopEnd="6dp"
                            app:boxCornerRadiusTopStart="6dp"
                            app:counterEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_cheque_number"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Bank Name Field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_bank_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:hint="@string/bank_name_hint"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="6dp"
                            app:boxCornerRadiusBottomStart="6dp"
                            app:boxCornerRadiusTopEnd="6dp"
                            app:boxCornerRadiusTopStart="6dp"
                            app:counterEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_bank_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Cheque Date Field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_cheque_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:hint="@string/cheque_date_hint"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="6dp"
                            app:boxCornerRadiusBottomStart="6dp"
                            app:boxCornerRadiusTopEnd="6dp"
                            app:boxCornerRadiusTopStart="6dp"
                            app:counterEnabled="false"
                            app:endIconDrawable="@android:drawable/ic_menu_today"
                            app:endIconMode="custom">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_cheque_date"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clickable="true"
                                android:focusable="false"
                                android:inputType="text"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Error Message -->
                        <TextView
                            android:id="@+id/tv_cheque_error"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="@string/cheque_required_error"
                            android:textColor="@android:color/holo_red_light"
                            android:textSize="11sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Bar -->
    <LinearLayout
        android:id="@+id/bottom_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="@dimen/space_md">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_invoice"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/save_invoice_button"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:backgroundTint="@color/navy_900"
            app:cornerRadius="6dp" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>



